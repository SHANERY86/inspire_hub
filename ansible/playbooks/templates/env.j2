# Managed by Ansible when .env is missing (docker-compose.ghcr.yml + Django).
# If you edit this file or inventory vars that map here: run `ansible-playbook … --tags env`
# so the target .env is rewritten; `stack` alone does not refresh an existing .env.
DEBUG={{ django_debug | default('False') }}
SECRET_KEY={{ django_key }}

DB_NAME={{ inspire_db_name | default('inspire_hub') }}
DB_USER={{ inspire_db_user | default(ansible_user) }}
DB_PASSWORD={{ ansible_become_password }}
DB_HOST=db
DB_PORT=5432

OCR_SPACE_API_KEY={{ ocr_api_key }}

{% if gmail_pass is defined and gmail_pass | trim | length > 0 %}
# Gmail SMTP — signup request emails (set vaulted `gmail_pass` on the host to enable).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=shanery86@gmail.com
EMAIL_HOST_PASSWORD={{ gmail_pass }}
DEFAULT_FROM_EMAIL=shanery86@gmail.com
SIGNUP_REQUEST_NOTIFICATION_EMAIL=shanery86@gmail.com
{% endif %}

# Trust X-Forwarded-Proto from nginx (set when HTTPS terminates at your router / Cloudflare / etc.).
TRUST_BEHIND_PROXY={{ django_trust_behind_proxy | default('True') }}

# Subpath deploy: mount urlconf at /<URL_PATH_PREFIX>/ (no leading/trailing slashes in value).
# Static/media URLs must stay under that prefix so Apache proxies them (see nginx alias on frontend).
URL_PATH_PREFIX={{ inspire_url_path_prefix | default('') }}
STATIC_URL={{ inspire_static_url | default('/inspire-hub/static/') }}
MEDIA_URL={{ inspire_media_url | default('/inspire-hub/media/') }}

ALLOWED_HOSTS={{ inspire_allowed_hosts | default('localhost,127.0.0.1,' ~ ansible_host) }}
{# Browser hits nginx on :8080; CSRF checks the full origin (scheme + host + port). #}
CSRF_TRUSTED_ORIGINS={{ inspire_csrf_origins | default('http://' ~ ansible_host ~ ',http://' ~ ansible_host ~ ':8080') }}

# docker-compose.ghcr.yml reads these at parse time (same refs Ansible uses in deploy.yml).
BACKEND_IMAGE={{ ghcr_registry | default('ghcr.io') }}/{{ ghcr_owner }}/inspire-hub-backend:{{ image_tag | default('latest') }}
FRONTEND_IMAGE={{ ghcr_registry | default('ghcr.io') }}/{{ ghcr_owner }}/inspire-hub-frontend:{{ image_tag | default('latest') }}

# Optional: true = Gunicorn access log + Django SQL timing on stdout (docker compose logs backend).
INSPIRE_DEV_LOGGING={{ 'true' if (inspire_dev_logging | default(false) | bool) else 'false' }}
